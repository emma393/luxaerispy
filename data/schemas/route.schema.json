{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Route",
  "type": "object",
  "required": [
    "route_slug",
    "origin_airport_slug",
    "destination_airport_slug",
    "primary_cabin",
    "route_summary"
  ],
  "properties": {
    "route_slug": {
      "type": "string"
    },
    "origin_airport_slug": {
      "type": "string"
    },
    "destination_airport_slug": {
      "type": "string"
    },
    "origin_city_slug": {
      "type": "string"
    },
    "destination_city_slug": {
      "type": "string"
    },
    "primary_cabin": {
      "type": "string"
    },
    "route_type": {
      "type": "string"
    },
    "estimated_duration_minutes": {
      "type": [
        "integer",
        "null"
      ]
    },
    "route_summary": {
      "type": "string"
    },
    "featured_image": {
      "type": [
        "string",
        "null"
      ]
    },
    "airline_slugs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "aircraft_slugs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "internal_notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}