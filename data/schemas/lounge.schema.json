{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lounge",
  "type": "object",
  "required": [
    "lounge_slug",
    "lounge_name",
    "airport_slug",
    "customer_summary"
  ],
  "properties": {
    "lounge_slug": {
      "type": "string"
    },
    "lounge_name": {
      "type": "string"
    },
    "airport_slug": {
      "type": "string"
    },
    "terminal_slug": {
      "type": [
        "string",
        "null"
      ]
    },
    "operator_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "access_rules": {
      "type": [
        "string",
        "null"
      ]
    },
    "opening_hours": {
      "type": [
        "string",
        "null"
      ]
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "customer_summary": {
      "type": "string"
    },
    "featured_image": {
      "type": [
        "string",
        "null"
      ]
    },
    "internal_notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}