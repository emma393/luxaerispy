{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Aircraft",
  "type": "object",
  "required": [
    "aircraft_slug",
    "model_name",
    "premium_summary"
  ],
  "properties": {
    "aircraft_slug": {
      "type": "string"
    },
    "family": {
      "type": [
        "string",
        "null"
      ]
    },
    "manufacturer": {
      "type": [
        "string",
        "null"
      ]
    },
    "model_name": {
      "type": "string"
    },
    "premium_summary": {
      "type": "string"
    },
    "featured_image": {
      "type": [
        "string",
        "null"
      ]
    },
    "related_airline_slugs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "internal_notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}